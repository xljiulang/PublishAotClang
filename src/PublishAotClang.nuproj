<Project Sdk="Microsoft.Build.NoTargets">
	<PropertyGroup>
		<TargetFramework>netstandard2.0</TargetFramework>
		<Version>1.0.0</Version>
		<Authors>Michal Strehovsky / Laojiu</Authors>
		<Description>用于在 Windows 上辅助 PublishAot 交叉编译到多个 linux RID 的 Nuget 包.</Description>
		<PackageProjectUrl>https://github.com/xljiulang/PublishAotClang</PackageProjectUrl>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageReadmeFile>README.md</PackageReadmeFile>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Vezel.Zig.Toolsets.win-x64" Version="0.16.0.2" PrivateAssets="None" />
	</ItemGroup>

	<ItemGroup>
		<None Include="build\**" PackagePath="build" Pack="true"/>
		<None Include="tools\**" PackagePath="tools" Pack="true"/>
		<None Include="../README.md" PackagePath="/" Pack="true" />
	</ItemGroup>
</Project>
