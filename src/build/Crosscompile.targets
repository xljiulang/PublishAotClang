<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

	<PropertyGroup>
		<DisableUnsupportedError>true</DisableUnsupportedError>
		<ZigVersion Condition="'$(ZigVersion)' == ''">0.16.0.2</ZigVersion>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Vezel.Zig.Toolsets.win-x64" Version="$(ZigVersion)">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
		</PackageReference>
	</ItemGroup>

	<UsingTask TaskName="PrependPath"
			   TaskFactory="RoslynCodeTaskFactory"
			   AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">

		<ParameterGroup>
			<Value ParameterType="System.String" Required="true" />
		</ParameterGroup>

		<Task>
			<Using Namespace="System" />
			<Using Namespace="System.IO" />
			<Code Type="Fragment" Language="cs">
				<![CDATA[
          Environment.SetEnvironmentVariable("PATH", Value + Path.PathSeparator + Environment.GetEnvironmentVariable("PATH"));
        ]]>
			</Code>
		</Task>

	</UsingTask>

	<Target Name="SetPathToZig" BeforeTargets="SetupOSSpecificProps">
		<Message Importance="high" Text="PublishAotZig: SetPathToZig '$(ZigToolsetPath)'" />
		<PrependPath Value="$(ZigToolsetPath)" />
	</Target>

	<Target Name="SetPathToClang" BeforeTargets="SetupOSSpecificProps">
		<PropertyGroup>
			<ClangToolsetPath>$([MSBuild]::NormalizeDirectory('$(MSBuildThisFileDirectory)../tools'))</ClangToolsetPath>
		</PropertyGroup>

		<Message Importance="high" Text="PublishAotZig: SetPathToClang '$(ClangToolsetPath)'" />
		<PrependPath Value="$(ClangToolsetPath)" />
	</Target>

	<!-- BEGIN: Works around ILCompiler targets not detecting this as a cross compilation -->
	<Target Name="OverwriteTargetTriple"
			AfterTargets="SetupOSSpecificProps"
			BeforeTargets="LinkNative">

		<PropertyGroup>
			<TargetTriple />
			<TargetTriple Condition="'$(RuntimeIdentifier)' == 'linux-x64'">x86_64-linux-gnu</TargetTriple>
			<!--当前目标运行时标识符“linux-x86”不支持提前编译-->
			<TargetTriple Condition="'$(RuntimeIdentifier)' == 'linux-x86'">i386-linux-gnu</TargetTriple>
			<TargetTriple Condition="'$(RuntimeIdentifier)' == 'linux-arm64'">aarch64-linux-gnu</TargetTriple>
			<TargetTriple Condition="'$(RuntimeIdentifier)' == 'linux-arm'">arm-linux-gnueabihf</TargetTriple>

			<TargetTriple Condition="'$(RuntimeIdentifier)' == 'linux-musl-x64'">x86_64-linux-musl</TargetTriple>
			<!--当前目标运行时标识符“linux-musl-x86”不支持提前编译-->
			<TargetTriple Condition="'$(RuntimeIdentifier)' == 'linux-musl-x86'">i386-linux-musl</TargetTriple>
			<TargetTriple Condition="'$(RuntimeIdentifier)' == 'linux-musl-arm64'">aarch64-linux-musl</TargetTriple>
			<TargetTriple Condition="'$(RuntimeIdentifier)' == 'linux-musl-arm'">arm-linux-musleabihf</TargetTriple>

			<RidLibsPath>$([MSBuild]::NormalizeDirectory('$(MSBuildThisFileDirectory)../tools/libs/$(RuntimeIdentifier)'))</RidLibsPath>
		</PropertyGroup>

		<Message Importance="high" Text="PublishAotZig: Set zig target to '$(TargetTriple)'" />
		<ItemGroup>
			<LinkerArg Include="--target=$(TargetTriple)" />
		</ItemGroup>

		<Message Importance="high" Text="PublishAotZig: Add library directory '$(RidLibsPath)'" Condition="Exists('$(RidLibsPath)')" />
		<ItemGroup Condition="Exists('$(RidLibsPath)')">
			<LinkerArg Include="-L$(RidLibsPath)"/>
		</ItemGroup>

	</Target>
	<!-- END: Works around ILCompiler targets not detecting this as a cross compilation -->

</Project>
